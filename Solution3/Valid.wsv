<Item XName="EquationText" Type="PartParam">
<DataEntry>% Example for DPD Validation&#x000D;&#x000A;% On Three Methods&#x000D;&#x000A;&#x000D;&#x000A;input_vector1 = [real(DPD_input_d5);&#x000D;&#x000A;&#x0009;&#x0009;&#x0009;&#x0009;real(DPD_input_d4);&#x000D;&#x000A;&#x0009;&#x0009;&#x0009;&#x0009;real(DPD_input_d3);&#x000D;&#x000A;&#x0009;&#x0009;&#x0009;&#x0009;real(DPD_input_d2);&#x000D;&#x000A;&#x0009;&#x0009;&#x0009;&#x0009;real(DPD_input_d1);&#x000D;&#x000A;&#x0009;&#x0009;&#x0009;&#x0009;real(DPD_input);&#x000D;&#x000A;&#x0009;&#x0009;&#x0009;&#x0009;imag(DPD_input_d5);&#x000D;&#x000A;&#x0009;&#x0009;&#x0009;&#x0009;imag(DPD_input_d4);&#x000D;&#x000A;&#x0009;&#x0009;&#x0009;&#x0009;imag(DPD_input_d3);&#x000D;&#x000A;&#x0009;&#x0009;&#x0009;&#x0009;imag(DPD_input_d2);&#x000D;&#x000A;&#x0009;&#x0009;&#x0009;&#x0009;imag(DPD_input_d1);&#x000D;&#x000A;&#x0009;&#x0009;&#x0009;&#x0009;imag(DPD_input)];&#x000D;&#x000A;&#x000D;&#x000A;data = load(&apos;X:\2-Github\DPD_of_a_3-ways_PA_with_Memory_Effects\Solution3\Method_A\Whole\GRU.mat&apos;);&#x000D;&#x000A;DPD_output_m = predict(data.model,input_vector1);&#x000D;&#x000A;DPD_output_m = double(DPD_output_m);&#x000D;&#x000A;DPD_output = DPD_output_m(1,:) + 1j * DPD_output_m(2,:);&#x000D;&#x000A;&#x000D;&#x000A;&#x000D;&#x000A;</DataEntry>
