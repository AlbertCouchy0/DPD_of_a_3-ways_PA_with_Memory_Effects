<Item XName="NMSE" UserName="NMSE" Type="Equation">
<Selected><T>Bool</T><D>0</D></Selected>
<Text>y1 = getvariable(&apos;DF1_Model_Original_Data&apos;, &apos;S2&apos;);&#x000D;&#x000A;x1 = getvariable(&apos;DF1_Model_Original_Data&apos;, &apos;S1&apos;);&#x000D;&#x000A;ox1 = x1;&#x000D;&#x000A;oy1 = y1;&#x000D;&#x000A;x = x1 / max(abs(x1));&#x000D;&#x000A;y = y1 / max(abs(y1));&#x000D;&#x000A;NMSE_Original_max = 10 * log10(sum(abs(y - x).^2) ./ sum(abs(x).^2));&#x000D;&#x000A;x = x1 / sum(abs(x1));&#x000D;&#x000A;y = y1 / sum(abs(y1));&#x000D;&#x000A;NMSE_Original_sum = 10 * log10(sum(abs(y - x).^2) ./ sum(abs(x).^2));&#x000D;&#x000A;x = (x1-min(x1))/(abs(max(x1)-min(x1)));&#x000D;&#x000A;y = (y1-min(y1))/(abs(max(y1)-min(y1)));&#x000D;&#x000A;NMSE_Original_minmax = 10 * log10(sum(abs(y - x).^2) ./ sum(abs(x).^2));&#x000D;&#x000A;&#x000D;&#x000A;&#x000D;&#x000A;&#x000D;&#x000A;y1 = getvariable(&apos;DF4_Model_C_Data&apos;, &apos;S2&apos;);&#x000D;&#x000A;x1 = getvariable(&apos;DF4_Model_C_Data&apos;, &apos;S1&apos;);&#x000D;&#x000A;x = x1 / max(abs(x1));&#x000D;&#x000A;y = y1 / max(abs(y1));&#x000D;&#x000A;NMSE_C_max = 10 * log10(sum(abs(y - x).^2) ./ sum(abs(x).^2));&#x000D;&#x000A;x = x1 / sum(abs(x1));&#x000D;&#x000A;y = y1 / sum(abs(y1));&#x000D;&#x000A;NMSE_C_sum = 10 * log10(sum(abs(y - x).^2) ./ sum(abs(x).^2));&#x000D;&#x000A;x = (x1-min(x1))/(abs(max(x1)-min(x1)));&#x000D;&#x000A;y = (y1-min(y1))/(abs(max(y1)-min(y1)));&#x000D;&#x000A;NMSE_C_minmax = 10 * log10(sum(abs(y - x).^2) ./ sum(abs(x).^2));</Text>
